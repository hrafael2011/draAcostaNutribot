# Copy to .env.local (or .env) for local dev. Vite only exposes vars prefixed with VITE_.

# Backend API base URL (must include /api suffix).
# Si usas ./scripts/start-backend.sh el puerto por defecto es 8001.
# Con Docker Compose + Nginx, el build usa VITE_API_BASE_URL=/api (mismo origen que el panel).
# En Vercel normalmente usarás la URL pública del backend Railway, por ejemplo:
# VITE_API_BASE_URL=https://tu-backend.up.railway.app/api
VITE_API_BASE_URL=http://localhost:8001/api
