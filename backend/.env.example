# Copy to .env and adjust. Never commit real secrets.

# --- App ---
# ENV=development
# APP_NAME=Diet Telegram Agent
# PORT=8000

# CORS: comma-separated origins, or * for any (dev only)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Auth ---
# Required in production: strong random string
JWT_SECRET=change-me-in-production

# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database (async SQLAlchemy) ---
# Railway/Postgres providers often expose postgres:// or postgresql:// URLs; the app
# normalizes them to asyncpg automatically at startup.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/diet_agent
# Con `docker compose`, DATABASE_URL se sobrescribe en docker-compose.yml (host `db`, no hace falta cambiar esto en el contenedor).

# --- OpenAI (diet generation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Plan PDF (ReportLab): GET /api/diets/{id}/pdf con JWT; el panel tiene "Download PDF" en el detalle de la dieta.

# --- ngrok (opcional: docker compose service `ngrok`; sync script usa http://127.0.0.1:14040) ---
# NGROK_AUTHTOKEN=
# Producción: si ya tienes un dominio estable (Railway/custom domain), puedes saltarte ngrok
# al registrar el webhook:
# WEBHOOK_PUBLIC_BASE_URL=https://tu-backend.up.railway.app

# --- Telegram bot ---
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_BOT_USERNAME=YourBotName
# Recomendado en producción: debe coincidir con X-Telegram-Bot-Api-Secret-Token al registrar el webhook
# TELEGRAM_WEBHOOK_SECRET=
#
# Enlace de vinculación (panel → Telegram → Generate link): t.me/<bot>?start=<codigo>.
# Ese codigo vive en la misma BD que los pacientes: se mantiene si no borras Postgres
# (en Docker, evita `docker compose down -v`). La URL HTTPS del túnel (ngrok) es para
# POST /api/telegram/webhook y puede cambiar al reiniciar ngrok; no sustituye al t.me.
